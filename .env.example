# ============================================================
#  Atlas — environment configuration (.env.example)
# ============================================================

# ── Server: database & boot ─────────────────────────────────
# Postgres connection string. REQUIRED — the server won't start witho
DATABASE_URL=postgres://atlas:atlas@localhost:5432/atlas

# Password for the root user seeded on the very first boot. Required only on
# first boot (when no users exist yet); ignored afterwards.
ATLAS_ROOT_PASSWORD=

# ── Server: HTTP & logging ──────────────────────────────────
# HTTP listen port (the server binds 0.0.0.0). Default: 8080
ATLAS_PORT=8080

# tracing/log filter. Default: info,atlas_server=debug,tower_http=info
RUST_LOG=info,atlas_server=debug,tower_http=info

# Public base URL used to build links (e.g. account activation) and reported
# by /health. Optional; empty if unset.
ATLAS_SERVER_URL=http://localhost:8080

# Build identifier reported by /health. Optional.
ATLAS_BUILD=

# ── Server: sessions & cookies ──────────────────────────────
# Session lifetime in hours. Default: 168 (7 days)
ATLAS_SESSION_TTL_HOURS=168
# Absolute max session lifetime in hours. Default: 720 (30 days)
ATLAS_SESSION_MAX_TTL_HOURS=720
# Secure flag on the session cookie. Default: true. Set to "false" (o
# for local HTTP development so the cookie is sent over http://.
ATLAS_COOKIE_SECURE=true

# ── Server: internals ───────────────────────────────────────
# Hash-chain anchor interval. Must be >= 2. Default: 50
ATLAS_ANCHOR_INTERVAL=50

# ── Server: attachments storage ─────────────────────────────
# Which backend stores uploaded files: "disk" (default) or "s3" (S3-c
# e.g. Cloudflare R2).
ATLAS_ATTACHMENT_BACKEND=disk

# disk backend: content-addressed root directory. Default: ./data/att
ATLAS_ATTACHMENT_ROOT=./data/attachments

# s3 backend (only when ATLAS_ATTACHMENT_BACKEND=s3). The first four
# in that case; startup fails naming any missing one (without echoing
ATLAS_S3_BUCKET=atlas-attachments
ATLAS_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
ATLAS_S3_ACCESS_KEY_ID=
ATLAS_S3_SECRET_ACCESS_KEY=
# Optional; R2 uses "auto" (default). Real AWS S3 wants a concrete re
ATLAS_S3_REGION=auto

# ============================================================
#  Agent tools (atlas_mcp / atlas_cli) — only if you run them
# ============================================================
# Atlas server URL these tools talk to. Default: http://localhost:808
ATLAS_BASE_URL=http://localhost:8080
# Bearer token (atlas_...). Required for the stdio MCP server and as
# token fallback. Keep it out of source control.
ATLAS_TOKEN=

# MCP HTTP transport (only when running the MCP server in http mode)
ATLAS_MCP_TRANSPORT=stdio      # stdio (default) | http
ATLAS_MCP_BIND=127.0.0.1       # http mode bind address
ATLAS_MCP_PORT=3001            # http mode port
