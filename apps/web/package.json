{
  "name": "@atlas/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "openapi-typescript openapi.json -o src/api/types.d.ts && vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "openapi-typescript openapi.json -o src/api/types.d.ts && vue-tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.4",
    "diff": "^9.0.0",
    "fuse.js": "^7.4.2",
    "katex": "^0.17.0",
    "lucide-vue-next": "^1.0.0",
    "mermaid": "^11.15.0",
    "pinia": "^3",
    "vue": "^3.5",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/node": "^22",
    "@vitejs/plugin-vue": "^6",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4",
    "typescript": "~6.0",
    "vite": "^8",
    "vitest": "^4.1.8",
    "vue-tsc": "^3"
  }
