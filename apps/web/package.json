{
  "name": "@atlas/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "openapi-typescript openapi.json -o src/api/types.d.ts && vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "openapi-typescript openapi.json -o src/api/types.d.ts && vue-tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tiptap/core": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "lucide-vue-next": "^1.0.0",
    "orderedmap": "^2.1.1",
    "pinia": "^3",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.8",
    "vue": "^3.5",
    "vue-router": "^5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/node": "^22",
    "@vitejs/plugin-vue": "^6",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4",
    "typescript": "~5.7",
    "vite": "^8",
    "vitest": "^4.1.8",
    "vue-tsc": "^3"
  }
}
