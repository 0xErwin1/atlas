{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atlas Desktop",
  "version": "0.0.0",
  "identifier": "me.feuer.atlas.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../web dev --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Atlas",
        "width": 1200,
        "height": 800,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
